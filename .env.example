DISCORD_TOKEN=your_discord_bot_token
# After enabling "Server Members Intent" on the Bot tab, set to 1 for better leaderboard names
DISCORD_ENABLE_MEMBERS_INTENT=
# After enabling "Message Content Intent" on the Bot tab, set to 1 for keyword auto-replies
DISCORD_ENABLE_MESSAGE_CONTENT_INTENT=

# League of Legends + Riot account lookup (https://developer.riotgames.com/)
RIOT_API_KEY=RGAPI_xxxxxxxx

# Valorant — Tracker.gg (https://tracker.gg/developers) header TRN-Api-Key
TRACKER_GG_API_KEY=
# auto | tracker | henrik — auto uses Tracker when TRACKER_GG_API_KEY is set (404 on Tracker falls back to Henrik)
VALORANT_RANK_PROVIDER=auto

# Henrik (optional fallback / if provider is henrik): https://discord.gg/X3GaVkX2YN
HENRIK_API_KEY=
